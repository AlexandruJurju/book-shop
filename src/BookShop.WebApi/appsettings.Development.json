{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "BookShop.WebApi"
    }
  },
  "Jobs": {
    "OutboxJobOptions": {
      "Cron": "*/10 * * * * *",
      "BatchSize": 1000
    },
    "InboxJobOptions": {
      "Cron": "*/10 * * * * *",
      "BatchSize": 1000
    }
  },
  "Caching": {
    "MaximumPayloadBytes": 1048576,
    "LocalExpirationInMinutes": 10,
    "DistributedExpirationInMinutes": 30
  },
  "Keycloak": {
    "BaseUrl": "http://localhost:8080/",
    "Realm": "book-shop",
    "PublicClientId": "public-client",
    "ConfidentialClientId": "confidential-client",
    "ConfidentialClientSecret": "c6KfL7ZFjGnxkfNDB122ytLN7LbdG3Qa"
  },
  "Authentication": {
    "Audience": "account",
    "MetadataAddress": "http://localhost:8080/realms/book-shop/.well-known/openid-configuration",
    "RequireHttpsMetadata": false,
    "TokenValidationParameters": {
      "ValidIssuers": [
        "https://localhost:8080/realms/book-shop",
        "https://localhost:18080/realms/book-shop"
      ]
    }
  }
}
